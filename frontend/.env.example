# say-6 frontend 환경변수
# 실제 사용 시 .env 파일로 복사 후 값 채우기 (.env는 .gitignore에 포함)

# ─────────────────────────────────────────────────────────────
# AWS Cognito JWT 인증 (운영)
# ─────────────────────────────────────────────────────────────
# 미설정 시 자동으로 데모 모드(역할 토글)로 fallback 됩니다.

# Cognito User Pool Domain (User Pool → App integration → Domain)
VITE_COGNITO_DOMAIN=say-6.auth.ap-northeast-2.amazoncognito.com

# Cognito User Pool App Client ID
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 로그인 콜백 URL (Cognito App Client의 Callback URLs와 일치해야 함)
VITE_COGNITO_REDIRECT_URI=http://localhost:3000/v2/auth/callback

# 리전 + User Pool ID (선택 — 백엔드 JWT 검증용 메타데이터)
VITE_COGNITO_REGION=ap-northeast-2
VITE_COGNITO_USER_POOL_ID=ap-northeast-2_xxxxxxxxx

# ─────────────────────────────────────────────────────────────
# 백엔드 API 베이스 URL
# ─────────────────────────────────────────────────────────────
# 기본값: Vite proxy 사용 ("" 이면 프록시)
VITE_API_BASE=
